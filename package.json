{
  "name": "butter-modal",
  "version": "1.0.7",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsup --watch",
    "test": "vitest run",
    "build": "tsup",
    "ci": "npm run build && npm run check-format && npm run test",
    "format": "prettier --write .",
    "check-format": "prettier --check ."
  },
  "keywords": [
    "modal",
    "dialog",
    "multi-step",
    "wizard",
    "framer-motion",
    "radix-ui",
    "animated",
    "react"
  ],
  "author": "Arnav Nath",
  "license": "ISC",
  "description": "A smoothly animated modal for React",
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "framer-motion": "^12.34.3",
    "prettier": "^3.8.1",
    "styled-components": "^6.3.11",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "resolutions": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "overrides": {
    "@radix-ui/react-dialog": "$@radix-ui/react-dialog"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArnavNath550/buttermodal.git"
  },
  "bugs": {
    "url": "https://github.com/ArnavNath550/buttermodal/issues"
